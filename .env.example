# Local development can use SQLite:
DATABASE_URL="file:../db/custom.db"

# Vercel production must use PostgreSQL:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
# DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Required for Bearer session-token signing. Use a random 32+ character value.
# SESSION_SECRET is preferred; AUTH_SECRET, NEXTAUTH_SECRET, or JWT_SECRET also work.
SESSION_SECRET="replace-with-a-random-32-plus-character-secret"

NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Public self-registration is disabled by default in production.
ALLOW_PUBLIC_REGISTRATION="false"

# Required only while running `npm run db:seed:admin` for the first time.
INITIAL_ADMIN_EMAIL=""
INITIAL_ADMIN_PASSWORD=""
INITIAL_ADMIN_USERNAME=""
INITIAL_ADMIN_FIRST_NAME=""
INITIAL_ADMIN_LAST_NAME=""

# Optional OneID placeholders:
ONEID_CLIENT_ID=""
ONEID_CLIENT_SECRET=""
ONEID_AUTH_URL=""
ONEID_REDIRECT_URI=""
ONEID_SCOPE=""
